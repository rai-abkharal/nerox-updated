NODE_ENV=production
PORT=5000
APP_URL=https://api.neroxvpn.com

DATABASE_URL=postgresql://postgres:change_me@localhost:5432/nerox_vpn
JWT_SECRET=change_me_to_a_long_random_secret

# Backend server key that can SSH into every WireGuard node.
SSH_PRIVATE_KEY_PATH=/root/.ssh/id_rsa
SSH_USER=root
SSH_PORT=22

# WireGuard defaults. Per-server values can be stored in vpn_servers too.
WG_INTERFACE=wg0
WG_DNS=1.1.1.1
WG_ALLOWED_IPS=0.0.0.0/0
WG_MONITORING_ENABLED=true

# Optional mail/payment config.
RESEND_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON={}
APPLE_SHARED_SECRET=
